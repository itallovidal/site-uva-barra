# Server environment
NODE_ENV=development          # "development" | "production" | "test" (default: "development")
PORT=3000                     # Server port (default: 3000)
HOST=0.0.0.0                  # Server host (default: "0.0.0.0")

# Auth
JWT_SECRET=your-secret-key    # JWT signing secret (default: "dev-secret")

# Firebase (required for production)
FIREBASE_PROJECT_ID=          # Firebase project ID
FIREBASE_CLIENT_EMAIL=        # Firebase client email
FIREBASE_PRIVATE_KEY=         # Firebase private key (with literal \n)

# Client-side (VITE_ prefix — exposed to browser)
VITE_ENABLE_MSW=true          # Enable MSW mock service worker (default: false)
VITE_API_BASE_URL=            # API base URL, empty = same-origin (default: "")
